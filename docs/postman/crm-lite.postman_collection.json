{
  "info": {
    "name": "CRM Lite API",
    "_postman_id": "8dbfc8d3-4a4a-49ae-8eb9-f0c98b837c0d",
    "description": "Postman collection for the CRM Lite take-home submission.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login/",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPass123\"\n}" }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh/",
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me/"
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/customers/"
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/customers/",
            "body": { "mode": "raw", "raw": "{\n  \"company_name\": \"Acme Inc.\",\n  \"contact_person\": \"Jane Doe\",\n  \"email\": \"jane@acme.com\",\n  \"phone\": \"+14155550123\",\n  \"industry\": \"Software\",\n  \"status\": \"ACTIVE\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "List Leads",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leads/"
          }
        },
        {
          "name": "Assign Lead",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/leads/1/assign/",
            "body": { "mode": "raw", "raw": "{\n  \"assigned_to_id\": 1\n}" }
          }
        }
      ]
    },
    {
      "name": "Sales Representatives",
      "item": [
        {
          "name": "List Representatives",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/sales-representatives/"
          }
        },
        {
          "name": "Representative Options",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/sales-representatives/options/"
          }
        }
      ]
    },
    {
      "name": "Opportunities",
      "item": [
        {
          "name": "List Opportunities",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/opportunities/"
          }
        },
        {
          "name": "Create Opportunity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/opportunities/",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Renewal Expansion\",\n  \"lead_id\": 1,\n  \"owner_id\": 1,\n  \"stage\": \"QUALIFICATION\",\n  \"amount\": \"15000.00\",\n  \"probability\": 40\n}" }
          }
        },
        {
          "name": "Update Opportunity Stage",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/opportunities/1/stage/",
            "body": { "mode": "raw", "raw": "{\n  \"stage\": \"PROPOSAL\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Admin Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/dashboard/admin/summary/"
          }
        },
        {
          "name": "Sales Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/dashboard/sales/summary/"
          }
        }
      ]
    }
  ]
}
